# Copy to .env for local dev / running the one-time migration scripts.
# Local Supabase stack (npx supabase start) prints these values — the demo keys
# it uses are fixed/public by convention, not secrets.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Real secrets — get an API key from console.anthropic.com; pick any local
# passphrase for APP_SHARED_SECRET during dev (it just needs to match what the
# client sends once the passphrase gate exists — see a later issue).
ANTHROPIC_API_KEY=
APP_SHARED_SECRET=
