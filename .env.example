# Copy to .env for local dev / running the one-time migration scripts.
# Local Supabase stack (npx supabase start) prints these values — the demo keys
# it uses are fixed/public by convention, not secrets.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Personal access token for the Supabase CLI (`supabase link` / `db push`
# against a real project) — generate at supabase.com/dashboard/account/tokens.
# Not needed for local-only dev (npx supabase start/stop/reset).
SUPABASE_ACCESS_TOKEN=

# Real secret — get an API key from console.anthropic.com.
ANTHROPIC_API_KEY=
